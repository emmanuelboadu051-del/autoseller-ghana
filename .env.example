# Core Flask security
FLASK_SECRET_KEY=change-this-to-a-long-random-secret
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
DATABASE_URL=sqlite:///autoseller.db

# Default admin bootstrap
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-this-admin-password

# Optional auth policy
SELF_SIGNUP_REQUIRE_APPROVAL=false

# Existing integrations (examples)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
ALERT_WHATSAPP_TO=

PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
